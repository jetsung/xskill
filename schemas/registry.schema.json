{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://xskill.gcli.cn/registry.schema.json",
  "title": "Registry Index",
  "description": "Skills index data generated by the registry sync workflow.",
  "type": "object",
  "properties": {
    "updated_at": {
      "description": "Last updated timestamp in ISO 8601 format.",
      "type": "string",
      "format": "date-time"
    },
    "sources": {
      "description": "Skills grouped by source repository.",
      "type": "array",
      "items": {
        "$ref": "#/$defs/SourceEntry"
      }
    }
  },
  "required": ["updated_at", "sources"],
  "additionalProperties": false,
  "$defs": {
    "SourceEntry": {
      "description": "Skills from a single source repository.",
      "type": "object",
      "properties": {
        "source": {
          "description": "Source name (e.g. org/repo).",
          "type": "string"
        },
        "url": {
          "description": "Source repository URL.",
          "type": "string",
          "format": "uri"
        },
        "skills": {
          "description": "Skills available from this source.",
          "type": "array",
          "items": {
            "$ref": "#/$defs/SkillEntry"
          }
        }
      },
      "required": ["source", "url", "skills"],
      "additionalProperties": false
    },
    "SkillEntry": {
      "description": "A single skill entry.",
      "type": "object",
      "properties": {
        "name": {
          "description": "Skill name.",
          "type": "string"
        },
        "path": {
          "description": "Path to SKILL.md relative to repository root.",
          "type": "string"
        },
        "description": {
          "description": "Skill description.",
          "type": "string",
          "default": ""
        },
        "version": {
          "description": "Skill version.",
          "type": "string",
          "default": ""
        }
      },
      "required": ["name", "path"],
      "additionalProperties": false
    }
  }
}
